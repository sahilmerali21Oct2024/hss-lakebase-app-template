"""Health and diagnostic routes -- always included."""

from fastapi import APIRouter
from server.auth.config import APP_NAME, IS_DEPLOYED
import os

from server.db.lakebase import db

router = APIRouter()


@router.get("/api/health")
async def health():
    result = {"status": "ok", "app": APP_NAME, "deployed": IS_DEPLOYED}
    pool = await db.get_pool()
    result["lakebase"] = "connected" if pool else "demo_mode"
    return result


@router.get("/api/env")
async def env_check():
    check = [
        "LAKEBASE_PROJECT",
        "LAKEBASE_BRANCH",
        "LAKEBASE_DATABASE",
        "LAKEBASE_USE_CASE_GROUP",
        "DATABRICKS_HOST",
        "DATABRICKS_APP_NAME",
        "APP_NAME",
        "EXPECTED_GIT_SHA",
    ]
    return {v: "SET" if os.environ.get(v) else "MISSING" for v in check}


@router.get("/api/lakebase/test")
async def lakebase_test():
    pool = await db.get_pool()
    if not pool:
        return {"status": "demo_mode"}
    try:
        async with pool.acquire() as conn:
            return {
                "status": "connected",
                "project": os.environ.get("LAKEBASE_PROJECT"),
                "branch": os.environ.get("LAKEBASE_BRANCH"),
                "database": os.environ.get("LAKEBASE_DATABASE"),
                "test": await conn.fetchval("SELECT 1"),
            }
    except Exception as e:
        return {"status": "error", "error": str(e)}
