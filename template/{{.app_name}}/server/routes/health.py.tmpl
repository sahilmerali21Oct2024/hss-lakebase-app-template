@router.get("/api/data-api/info")
async def data_api_info():
    """Stub showing where the Data API URL would live for this app.

    After scripts/enable_data_api.py runs, the URL is visible in the Lakebase
    UI under your project's Data API tab. Apps can either:
      (a) call it server-side via their app SP, or
      (b) hand the URL to the browser with the user's OBO token attached.
    """
    return {
        "data_api_enabled": True,
        "project": os.environ.get("LAKEBASE_PROJECT"),
        "branch": os.environ.get("LAKEBASE_BRANCH"),
        "note": "See Lakebase project UI -> Data API for the actual URL.",
    }
