import os
import sys

from server.middleware.audit_logger import AuditLoggerMiddleware
from server.routes import health

{{if eq .use_lakebase "yes"}}from server.db.lakebase import db{{end}}


def _enforce_ci_deploy() -> None:
    """Refuse to start if EXPECTED_GIT_SHA was not injected by the CI pipeline.

    The CI deploy job patches this env var into the App resource AFTER a successful
    bundle deploy. A manual `bundle deploy` or workspace-UI upload never sets it.
    If you see this app failing to start, someone deployed manually — open a PR
    and let the GitHub Actions pipeline redeploy it.

    Set ALLOW_UNVERIFIED_DEPLOY=1 only for local development.
    """
    if os.environ.get("ALLOW_UNVERIFIED_DEPLOY") == "1":
        return
    if not os.environ.get("DATABRICKS_APP_NAME"):
        return  # local dev — no enforcement
    expected = os.environ.get("EXPECTED_GIT_SHA")
    if not expected:
        print(
            "BLOCKED: this app was deployed without going through the CI pipeline.\n"
            "The EXPECTED_GIT_SHA env var is missing. Manual `databricks bundle deploy`\n"
            "and workspace-UI uploads do not set it. Open a PR and let the GitHub\n"
            "Actions deploy workflow run instead. See docs/PROD_LOCKDOWN.md.",
            file=sys.stderr,
            flush=True,
        )
        sys.exit(2)


_enforce_ci_deploy()


@asynccontextmanager
async def lifespan(app: FastAPI):
    {{if eq .use_lakebase "yes"}}await db.get_pool()
    print(f"App started. Lakebase: {'connected' if not db.is_demo_mode else 'demo mode'}"){{else}}print("App started."){{end}}
    yield
    {{if eq .use_lakebase "yes"}}await db.close(){{end}}
    print("App shut down.")


app = FastAPI(title="{{.app_name}}", lifespan=lifespan)
app.add_middleware(AuditLoggerMiddleware)
app.include_router(health.router)

