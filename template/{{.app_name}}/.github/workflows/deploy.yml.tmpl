name: Deploy App

# End-to-end deploy:
#   1. VALIDATE (gate) — same checks as PR validator, runs even on direct-to-main pushes.
#   2. DEPLOY — migrate -> bundle deploy -> grants -> restart -> smoke -> record SHA.
#
# The deploy job depends on validate, so a failed validator aborts the deploy.
# A manual `bundle deploy -t prod` from a laptop bypasses this entirely — for
# that, see docs/PROD_LOCKDOWN.md (workspace-side enforcement).
on:
  push:
    branches: [main]
  workflow_dispatch:
    inputs:
      target:
        description: "Deploy target"
        required: true
        type: choice
        options: [dev, prod]

concurrency:
  group: deploy-${{"{{"}} github.event.inputs.target || 'dev' {{"}}"}}
  cancel-in-progress: false

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install pyyaml
        run: pip install pyyaml

      - name: Run shared validators
        env:
          DEV_CATALOG: {{.dev_catalog}}
          PROD_CATALOG: {{.prod_catalog}}
        run: bash scripts/run_validators.sh

  deploy:
    needs: validate
    runs-on: ubuntu-latest
    environment: ${{"{{"}} github.event.inputs.target || 'dev' {{"}}"}}
    env:
      TARGET: ${{"{{"}} github.event.inputs.target || 'dev' {{"}}"}}
      APP_NAME: {{.app_name}}
      LAKEBASE_PROJECT: {{.use_case_group}}
      LAKEBASE_DATABASE: {{.database_name}}
      LAKEBASE_BRANCH: production
      DATABRICKS_HOST: ${{"{{"}} vars.DATABRICKS_HOST {{"}}"}}
      DATABRICKS_CLIENT_ID: ${{"{{"}} vars.DATABRICKS_CLIENT_ID {{"}}"}}
      DATABRICKS_CLIENT_SECRET: ${{"{{"}} secrets.DATABRICKS_CLIENT_SECRET {{"}}"}}
      UC_CATALOG: ${{"{{"}} vars.UC_CATALOG {{"}}"}}
      UC_WAREHOUSE_ID: ${{"{{"}} vars.UC_WAREHOUSE_ID {{"}}"}}
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install tooling
        run: pip install -r requirements.txt

      - uses: databricks/setup-cli@main

      - name: Validate bundle
        run: databricks bundle validate -t $TARGET

      - name: Run database migrations (alembic upgrade head)
        run: |
          echo "Migrating Lakebase project=$LAKEBASE_PROJECT branch=$LAKEBASE_BRANCH db=$LAKEBASE_DATABASE"
          alembic upgrade head
        # Failure here aborts the deploy — the app is NOT restarted on an
        # uncommitted schema change. Roll back with scripts/rollback_migration.py.

      - name: Show current schema revision
        run: alembic current

      - name: Deploy bundle
        run: databricks bundle deploy -t $TARGET

      - name: Apply app SP grants (Lakebase + UC)
        run: python scripts/apply_grants.py --app-name "$APP_NAME"

      - name: Apply group grants (if any declared in permissions.yaml)
        run: python scripts/apply_group_grants.py
{{if eq .expose_data_api "yes"}}
      - name: Enable Lakebase Data API for this project
        run: python scripts/enable_data_api.py
{{end}}
      - name: Inject EXPECTED_GIT_SHA into the app
        # Patches the deployed app's env so the in-process self-check can refuse
        # to start if someone later does a manual redeploy from a different SHA.
        run: |
          python - <<PY
          import os, json, subprocess
          sha = os.environ["GITHUB_SHA"]
          app = os.environ["APP_NAME"]
          env_list = [
              {"name": "EXPECTED_GIT_SHA", "value": sha},
              {"name": "DEPLOY_TIMESTAMP", "value": os.environ.get("GITHUB_RUN_ID", "")},
          ]
          data_api_url = os.environ.get("LAKEBASE_DATA_API_URL")
          if data_api_url:
              env_list.append({"name": "LAKEBASE_DATA_API_URL", "value": data_api_url})
          subprocess.run(
              ["databricks", "apps", "update", app,
               "--update-mask", "config.env",
               "--json", json.dumps({"config": {"env": env_list}})],
              check=True,
          )
          PY

      - name: Restart app
        run: databricks apps restart "$APP_NAME"

      - name: Smoke test /api/health
        run: |
          set -e
          for i in 1 2 3 4 5 6; do
            URL=$(databricks apps get "$APP_NAME" --output json | python -c \
              "import sys,json;print(json.load(sys.stdin).get('url',''))")
            if [ -n "$URL" ]; then
              code=$(curl -s -o /dev/null -w "%{http_code}" "$URL/api/health" || echo 000)
              echo "attempt $i -> $code"
              if [ "$code" = "200" ]; then exit 0; fi
            fi
            sleep 15
          done
          echo "::error::App did not become healthy after deploy."
          exit 1
